{
  "name": "office-tools",
  "version": "1.0.0",
  "description": "Office Tools Jekyll Site with Tailwind CSS",
  "scripts": {
    "build-css": "tailwindcss -i ./assets/input.css -o ./assets/main.css",
    "build-css-watch": "tailwindcss -i ./assets/input.css -o ./assets/main.css --watch",
    "build": "tailwindcss -i ./assets/input.css -o ./assets/main.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "tailwindcss": "^3.4.0"
  }
}
